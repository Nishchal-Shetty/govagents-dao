# Copy this file to agents/.env and fill in your values before running.
#   cp agents/.env.example agents/.env

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Network ───────────────────────────────────────────────────────────────────
# Local Hardhat node (default for demo):
RPC_URL=http://127.0.0.1:8545
# Sepolia testnet example:
# RPC_URL=https://sepolia.infura.io/v3/<YOUR_INFURA_PROJECT_ID>

# ── Contract ──────────────────────────────────────────────────────────────────
# Written automatically by `npm run deploy:local` — leave blank until deployed.
CONTRACT_ADDRESS=

# ── Wallet private keys ───────────────────────────────────────────────────────
# These must match the addresses registered via registerAgent() on-chain.
#
# For local Hardhat demo the values below are Hardhat's well-known
# deterministic test accounts (accounts[0–3]). They are PUBLIC — do NOT
# use them on any network with real funds.
#
# Replace all four keys before deploying to a public network.

# accounts[0] — submits proposals
PROPOSER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# accounts[1] — SecurityAgent  (0x70997970C51812dc3A010C7d01b50e0d17dc79C8)
SECURITY_AGENT_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# accounts[2] — EconomicAgent  (0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC)
ECONOMIC_AGENT_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# accounts[3] — GovernanceAgent (0x90F79bf6EB2c4f870365E785982E1f101E93b906)
GOVERNANCE_AGENT_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6
